  <li id=<%= citation.id %> class='citation'>
    <% if year < 0 %>
      <% if citation.pub_year.to_i != year  %>
        <% if @study %>
          <div class='pub-year'>Forthcoming <%= humanize_citation_type(@type)%> from the <%= @study.name %></div>
        <% else %>
          <div class='pub-year'>Forthcoming <%= humanize_citation_type(@type) %></div>
        <% end %>
      <% end %>
    <% else %>
      <% if citation.pub_year.to_i != year  %>
        <div class='pub-year'><%= citation.pub_year %></div>
      <% end %>
    <% end %>
    <% cache(citation, action: 'index') do %>
      <div>
       <p><%= citation.author_and_year(long: true) %><em> <%= citation.title %></em>.
       <% if citation.series_title.present? %> <%= citation.series_title %>, <% end %>
       <%= citation.publication %> <%= citation.volume_and_page %>
       <%= citation.publisher %> <%= citation.city %>
      <% if citation.doi.present? %>
        <span> <em>DOI: <%= link_to citation.doi, normalize_doi(citation.doi) %></em></span>
      <% end %>
        </p>
        <div>
          <div class="citation-footer">
            <div>
              <% if citation.pdf.attached? && citation.open_access %>
                <span class='non-member'>
                  <%= link_to 'abstract', citation_path(citation), aria: { label: "view #{citation.title} abstract" } %>
                  &nbsp;&nbsp;
                  <%= link_to 'pdf', publication_url(citation), aria: { label: "view pdf for #{citation.title}" } %>
                </span>
                <span class='member-only'>
                  <%= link_to 'abstract', citation_path(citation), aria: { label: "view #{citation.title} abstract" } %>
                  &nbsp;&nbsp;
                  <%= link_to 'pdf', publication_url(citation), aria: { label: "view pdf for #{citation.title}" } %>
                </span>
              <% elsif citation.pdf.attached? %>
                <span class='non-member'>
                  <%= link_to 'abstract + pdf', citation_path(citation), aria: { label: "view #{citation.title} abstract and pdf" } %>
                </span>
                <span class='member-only'>
                  <%= link_to 'abstract', citation_path(citation), aria: { label: "view #{citation.title} abstract" } %>
                  &nbsp;&nbsp;
                  <%= link_to 'pdf', publication_url(citation), aria: { label: "view pdf for #{citation.title}" } %>
                </span>
              <% else %>
                <span class='non-member'>
                  <%= link_to 'abstract', citation_path(citation), aria: { label: "view #{citation.title} abstract" } %>
                </span>
                <span class='member-only'>
                  <%= link_to 'abstract', citation_path(citation), aria: { label: "view #{citation.title} abstract" } %>
                </span>
              <% end %>
              <span>&nbsp;</span>
              <% if citation.data_url.present? %>
                <span>&nbsp;<a href="<%= normalize_doi(citation.data_url) %>" aria-label="view data for <%= citation.title %>">data</a>&nbsp;</span>
              <% else %>
                <span>&nbsp;</span>
              <% end %>
            </div>
            <% if citation.doi.present? %>
                <span>&nbsp;(<%=normalize_doi(citation.doi)%>)</span>
              <% else %>
              <span>&nbsp;<%= "https://lter.kbs.msu.edu/pub/#{citation.id}" %></span>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </li>