<div id='search-form'>
  <%= form_tag('/datatables/search') do %>

      <div id='bottom-line-search'>
        <div id='keyword-search'>
          <%= label_tag 'keyworder', 'Search data tables', class: 'sr-only' %>
          <%= text_field_tag :keyword_list, @keyword_list || @default_value,
          {:id => 'keyworder',
          placeholder: "Search for core areas, keywords, people, or doi's"} %>
        </div>
          <%= submit_tag "Search Data Tables", class: 'search-button' %>
      </div>
  <% end %>
</div>